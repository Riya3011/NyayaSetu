# NyayaSetu Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to git.

# MongoDB connection string
# Local MongoDB:   mongodb://localhost:27017/nyayasetu
# MongoDB Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/nyayasetu
MONGO_URI=mongodb://localhost:27017/nyayasetu

# Port the Express server listens on
PORT=5050

# Groq AI API key (for NyayaBot chat + document analysis)
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret — use a long random string, e.g. openssl rand -hex 64
JWT_SECRET=replace_this_with_a_very_long_random_secret_string

# JWT token expiry duration (e.g. 7d, 24h, 30d)
JWT_EXPIRES_IN=7d
